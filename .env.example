# ── LLM ──────────────────────────────────────────────
GROQ_API_KEY=
GOOGLE_AI_API_KEY=

# ── Supabase ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── LangSmith (optional) ─────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=asd-l2

# ── Upstash Redis (optional — narrative cache) ────────
# WARNING logged if missing; narrative falls back to Groq then static string
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Brevo (optional — email notifications) ────────────
# API key:  Brevo dashboard -> Settings -> SMTP & API -> API Keys tab
# SMTP key: Brevo dashboard -> Settings -> SMTP & API -> SMTP tab (for Supabase SMTP config)
# WARNING logged if BREVO_API_KEY missing; emails skipped gracefully
BREVO_API_KEY=
BREVO_FROM_EMAIL=

# ── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=
API_URL=
CORS_ORIGIN=

# ── Sentry (optional) ────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
